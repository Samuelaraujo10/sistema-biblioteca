<%- include("../partials/header") %>

<section class="page-heading">
  <h2>👥 Alunos</h2>
  <p>Gerencie os estudantes aptos a pegar livros emprestados.</p>
</section>

<div class="students-container">

  <!-- Barra de Ações -->
  <div style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
    <button id="btn-toggle-form" class="accent" style="display:flex; align-items:center; gap:8px;">
      <span style="font-size:1.1rem">➕</span> Cadastrar Novo Aluno
    </button>
    <a href="/students/import" class="secondary" style="display:flex; align-items:center; gap:8px; text-decoration:none;">
      <span style="font-size:1.1rem">CSV</span> Importar
    </a>
    <div style="flex-grow: 1; position: relative; min-width: 250px;">
      <span style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; color: var(--muted);">🔍</span>
      <input id="student-search" type="text" placeholder="Pesquisar por nome, turma, turno ou matrícula..."
        oninput="filterStudents(this.value)" style="padding-left: 42px; width: 100%;" />
    </div>
  </div>

  <!-- Card de Cadastro Colapsável -->
  <div id="form-card" class="card" style="margin-bottom: 28px; border-top: 4px solid var(--primary); padding: 0; max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s var(--t), opacity 0.3s var(--t), padding 0.4s var(--t);">
    <form action="/students" method="POST" style="margin: 0;">
      <h3 style="color: var(--text); font-size: 1.1rem; font-weight: 700; margin-bottom: 16px;">Novo Cadastro</h3>
      <div class="form-grid">
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Nome Completo:</label>
          <input type="text" name="name" required placeholder="Ex: Ana Souza" />
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Turma *</label>
          <select name="class_name" required>
            <option value="">Selecionar Turma</option>
            <option value="1ª série">1ª série</option>
            <option value="2ª série">2ª série</option>
            <option value="3ª série">3ª série</option>
          </select>
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Turno *</label>
          <select name="shift" required>
            <option value="">Selecionar Turno</option>
            <option value="Matutino">Matutino</option>
            <option value="Vespertino">Vespertino</option>
          </select>
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Matrícula *</label>
          <input type="text" name="registration" placeholder="12 dígitos" required inputmode="numeric" maxlength="12" pattern="[0-9]{12}" title="12 dígitos numéricos" oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,12)" />
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Telefone/WhatsApp:</label>
          <input type="text" name="phone" placeholder="(99) 99999-9999" />
        </div>
      </div>
      <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" class="secondary" id="btn-cancel-form">Cancelar</button>
        <button type="submit">Salvar</button>
      </div>
    </form>
  </div>

  <script>
    const btnToggle = document.getElementById('btn-toggle-form');
    const btnCancel = document.getElementById('btn-cancel-form');
    const formCard = document.getElementById('form-card');

    function openForm() {
      formCard.style.padding = '24px';
      formCard.style.maxHeight = '800px';
      formCard.style.opacity = '1';
      btnToggle.style.display = 'none';
      setTimeout(() => formCard.querySelector('input')?.focus(), 300);
    }

    function closeForm() {
      formCard.style.maxHeight = '0';
      formCard.style.opacity = '0';
      formCard.style.padding = '0';
      setTimeout(() => { btnToggle.style.display = 'flex'; }, 300);
    }

    btnToggle.addEventListener('click', openForm);
    btnCancel.addEventListener('click', closeForm);
  </script>

  <div class="table-wrap">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding: 0 8px;">
      <h3 style="font-size: 1.1rem; font-weight: 700;">Alunos Cadastrados</h3>
      <span style="font-size: 0.85rem; color: var(--muted);" id="student-count">Total: <%= students.length %></span>
    </div>
    <table id="students-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Turma</th>
          <th>Turno</th>
          <th>Matrícula</th>
          <th>Telefone</th>
          <th>Ação</th>
        </tr>
      </thead>
      <tbody>
        <% students.forEach((student) => { %>
          <tr>
            <td style="font-weight: 600;"><%= student.name %></td>
            <td><%= student.class_name %></td>
            <td><%= student.shift || '-' %></td>
            <td><%= student.registration %></td>
            <td>
              <% if (student.phone) { %>
                <a href="https://wa.me/55<%= String(student.phone).replace(/\D/g, '') %>" target="_blank" style="color:var(--success); display:flex; align-items:center; gap:4px;">
                  📱 <%= student.phone %>
                </a>
              <% } else { %>
                -
              <% } %>
            </td>
            <td class="td-actions">
              <a href="/students/<%= student.id %>/edit" class="btn-action btn-edit">✏️ Editar</a>
              <form action="/students/<%= student.id %>?_method=DELETE" method="POST" style="margin:0;">
                <button type="submit" class="btn-action btn-delete">🗑️ Excluir</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p id="no-results-student" style="display:none;text-align:center;color:#94a3b8;padding:24px;font-size:0.95rem;">Nenhum aluno encontrado para "<span id="search-term-student"></span>"</p>
  </div>
</div>

<script>
  function filterStudents(q) {
    const rows  = document.querySelectorAll('#students-table tbody tr');
    const term  = q.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const match = row.textContent.toLowerCase().includes(term);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const countEl = document.getElementById('student-count');
    const noRes   = document.getElementById('no-results-student');
    document.getElementById('search-term-student').textContent = q;
    countEl.textContent = term ? `Filtrados: ${visible}` : `Total: ${rows.length}`;
    noRes.style.display = (term && visible === 0) ? 'block' : 'none';
  }
</script>

<%- include("../partials/footer") %>
