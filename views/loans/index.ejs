<%- include("../partials/header") %>

<section class="page-heading">
  <h2>📖 Empréstimos</h2>
  <p>Controle retiradas, prazos e devoluções dos livros.</p>
</section>

<div class="loans-container">
  <!-- Alertas de vencimento -->
  <%
    const overdueLoans = loans.filter(l => l.dueDateStatus === 'overdue' && l.status === 'emprestado');
    const warningLoans = loans.filter(l => l.dueDateStatus === 'warning' && l.status === 'emprestado');
  %>

  <% if (overdueLoans.length > 0) { %>
    <div class="alert-overdue">
      <h3>⚠️ Empréstimos Vencidos</h3>
      <% overdueLoans.forEach((loan) => { %>
        <div class="alert-item">
          <strong><%= loan.book_title %></strong><br/>
          Aluno: <strong><%= loan.student_name %></strong>
          &nbsp;|&nbsp; Série: <%= loan.student_class || '-' %>
          &nbsp;|&nbsp; Turno: <%= loan.student_shift || '-' %>
          <% if (loan.student_phone) { %>
            &nbsp;|&nbsp; 📞 <a href="https://wa.me/55<%= loan.student_phone.replace(/\D/g, '') %>" target="_blank" style="color:#155724;">(<%= loan.student_phone %>)</a>
          <% } %><br/>
          <span class="overdue-badge">Vencido há <%= Math.abs(loan.daysUntilDue) %> dia(s)</span>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (warningLoans.length > 0) { %>
    <div class="alert-warning">
      <h3>⏰ Empréstimos Próximos ao Vencimento</h3>
      <% warningLoans.forEach((loan) => { %>
        <div class="alert-item">
          <strong><%= loan.book_title %></strong><br/>
          Aluno: <strong><%= loan.student_name %></strong>
          &nbsp;|&nbsp; Série: <%= loan.student_class || '-' %>
          &nbsp;|&nbsp; Turno: <%= loan.student_shift || '-' %>
          <% if (loan.student_phone) { %>
            &nbsp;|&nbsp; 📞 <a href="https://wa.me/55<%= loan.student_phone.replace(/\D/g, '') %>" target="_blank" style="color:#856404;">(<%= loan.student_phone %>)</a>
          <% } %><br/>
          <span class="warning-badge">Vence em <%= loan.daysUntilDue %> dia(s)</span>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Card colapsável de novo empréstimo -->
  <div id="new-loan-card" style="
    background: linear-gradient(135deg, #10b981 0%, #0ea5e9 100%);
    border-radius: 16px; padding: 20px 24px;
    display: flex; align-items: center; justify-content: space-between;
    cursor: pointer; box-shadow: 0 4px 20px rgba(16,185,129,0.3);
    transition: box-shadow 0.2s, transform 0.2s; margin-bottom: 4px; user-select: none;
  "
  onmouseover="this.style.boxShadow='0 8px 30px rgba(16,185,129,0.45)';this.style.transform='translateY(-2px)'"
  onmouseout="this.style.boxShadow='0 4px 20px rgba(16,185,129,0.3)';this.style.transform=''"
  onclick="toggleLoanForm()">
    <div style="display:flex;align-items:center;gap:14px;">
      <div style="background:rgba(255,255,255,0.2);border-radius:10px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;font-size:20px;">📋</div>
      <div>
        <div style="color:white;font-weight:700;font-size:1rem;">Registrar Novo Empréstimo</div>
        <div style="color:rgba(255,255,255,0.75);font-size:0.8rem;margin-top:2px;">Clique para expandir o formulário</div>
      </div>
    </div>
    <div id="chevron-loan" style="color:white;font-size:1.3rem;transition:transform 0.3s;">▼</div>
  </div>

  <div id="loan-form-wrapper" style="max-height:0;overflow:hidden;transition:max-height 0.45s cubic-bezier(0.4,0,0.2,1),opacity 0.3s ease;opacity:0;">
    <form action="/loans" method="POST" style="
      background:white;border:1px solid #a7f3d0;border-top:none;
      border-radius:0 0 16px 16px;padding:28px 24px 24px;
      box-shadow:0 8px 24px rgba(16,185,129,0.08);">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;">
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.78rem;font-weight:600;color:#10b981;letter-spacing:0.05em;text-transform:uppercase;">Livro *</label>
          <select name="id_livro" required style="border:1.5px solid #a7f3d0;border-radius:9px;padding:10px 13px;font-size:0.92rem;outline:none;background:white;transition:border-color 0.2s;" onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='#a7f3d0'">
            <option value="">Selecione o livro</option>
            <% books.forEach((book) => { %>
              <% if (book.availableCopies > 0) { %>
                <option value="<%= book.id %>"><%= book.title %> (<%= book.availableCopies %> disponíveis)</option>
              <% } %>
            <% }) %>
          </select>
        </div>
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.78rem;font-weight:600;color:#10b981;letter-spacing:0.05em;text-transform:uppercase;">Aluno *</label>
          <select name="student_id" required style="border:1.5px solid #a7f3d0;border-radius:9px;padding:10px 13px;font-size:0.92rem;outline:none;background:white;transition:border-color 0.2s;" onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='#a7f3d0'">
            <option value="">Selecione o aluno</option>
            <% students.forEach((student) => { %>
              <option value="<%= student.id %>"><%= student.name %></option>
            <% }) %>
          </select>
        </div>
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.78rem;font-weight:600;color:#10b981;letter-spacing:0.05em;text-transform:uppercase;">Data Empréstimo *</label>
          <input type="date" name="loan_date" id="loan_date" required style="border:1.5px solid #a7f3d0;border-radius:9px;padding:10px 13px;font-size:0.92rem;outline:none;transition:border-color 0.2s;" onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='#a7f3d0'"/>
        </div>
        <div style="display:flex;flex-direction:column;gap:5px;">
          <label style="font-size:0.78rem;font-weight:600;color:#10b981;letter-spacing:0.05em;text-transform:uppercase;">Devolução Prevista *</label>
          <input type="date" name="due_date" id="due_date" required style="border:1.5px solid #a7f3d0;border-radius:9px;padding:10px 13px;font-size:0.92rem;outline:none;transition:border-color 0.2s;" onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='#a7f3d0'"/>
        </div>
      </div>
      <div style="display:flex;gap:10px;margin-top:20px;justify-content:flex-end;">
        <button type="button" onclick="toggleLoanForm()" style="background:#f1f5f9;color:#64748b;border:none;border-radius:9px;padding:10px 20px;font-weight:600;cursor:pointer;font-size:0.92rem;">Cancelar</button>
        <button type="submit" style="background:linear-gradient(135deg,#10b981,#0ea5e9);color:white;border:none;border-radius:9px;padding:10px 26px;font-weight:700;cursor:pointer;font-size:0.92rem;box-shadow:0 4px 12px rgba(16,185,129,0.35);">✓ Registrar</button>
      </div>
    </form>
  </div>

  <!-- Barra de pesquisa -->
  <div style="margin:20px 0 12px;position:relative;">
    <span style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:1rem;pointer-events:none;">🔍</span>
    <input id="loan-search" type="text" placeholder="Pesquisar por livro, aluno ou status..."
      oninput="filterLoans(this.value)"
      style="width:100%;padding:12px 16px 12px 40px;border:1.5px solid #e2e8f0;border-radius:12px;font-size:0.92rem;outline:none;transition:border-color 0.2s;box-sizing:border-box;background:white;"
      onfocus="this.style.borderColor='#10b981'" onblur="this.style.borderColor='#e2e8f0'"/>
    <span id="loan-count" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:0.8rem;"></span>
  </div>

  <div class="table-wrap">
    <table id="loans-table">
      <thead>
        <tr>
          <th>Livro</th>
          <th>Aluno</th>
          <th>Data Empréstimo</th>
          <th>Data Devolução Prevista</th>
          <th>Status</th>
          <th>Ação</th>
        </tr>
      </thead>
      <tbody>
        <% loans.forEach((loan) => { %>
          <tr class="<%= loan.dueDateStatus === 'overdue' ? 'row-overdue' : loan.dueDateStatus === 'warning' ? 'row-warning' : '' %>">
            <td><%= loan.book_title %> (Cópia <%= loan.copy_id %>)</td>
            <td><%= loan.student_name %></td>
            <td><%= loan.loan_date %></td>
            <td><%= loan.due_date %></td>
            <td>
              <span class="status-pill <%= loan.status === 'emprestado' ? 'is-active' : 'is-returned' %>">
                <%= loan.status %>
              </span>
              <% if (loan.dueDateStatus === 'overdue') { %>
                <span class="badge-overdue">Vencido</span>
              <% } else if (loan.dueDateStatus === 'warning') { %>
                <span class="badge-warning">Alerta</span>
              <% } %>
            </td>
            <td class="td-actions">
              <% if (loan.status === "emprestado") { %>
                <form action="/loans/<%= loan.id %>/return?_method=PATCH" method="POST" style="margin:0;">
                  <button type="submit" class="btn-action btn-return">✅ Devolver</button>
                </form>
                <% if (loan.dueDateStatus !== 'overdue') { %>
                  <form action="/loans/<%= loan.id %>/extend?_method=PATCH" method="POST" style="margin:0;">
                    <button type="submit" class="btn-action btn-renew">🔄 Renovar +7d</button>
                  </form>
                <% } %>
              <% } else { %>
                <span style="font-size:0.85rem;color:#6b7280;">✔ Devolvido em <%= loan.return_date %></span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const loanDateInput = document.getElementById('loan_date');
    const dueDateInput = document.getElementById('due_date');

    if (loanDateInput && dueDateInput) {
      const today = new Date();
      const todayStr = today.toISOString().split('T')[0];
      
      const defaultMaxDate = new Date(today);
      defaultMaxDate.setDate(defaultMaxDate.getDate() + 14);
      const defaultMaxDateStr = defaultMaxDate.toISOString().split('T')[0];

      loanDateInput.value = todayStr;
      dueDateInput.value = defaultMaxDateStr;
      
      loanDateInput.addEventListener('change', () => {
        const selectedLoan = new Date(loanDateInput.value);
        if(!isNaN(selectedLoan.getTime())) {
           const newMax = new Date(selectedLoan);
           newMax.setDate(newMax.getDate() + 14);
           dueDateInput.max = newMax.toISOString().split('T')[0];
           dueDateInput.min = loanDateInput.value;
        }
      });
      
      loanDateInput.dispatchEvent(new Event('change'));
    }
  });

  function toggleLoanForm() {
    const wrapper = document.getElementById('loan-form-wrapper');
    const card    = document.getElementById('new-loan-card');
    const chevron = document.getElementById('chevron-loan');
    const isOpen  = wrapper.style.maxHeight !== '0px' && wrapper.style.maxHeight !== '';
    if (isOpen) {
      wrapper.style.maxHeight = '0'; wrapper.style.opacity = '0';
      card.style.borderRadius = '16px'; chevron.style.transform = '';
    } else {
      wrapper.style.maxHeight = '900px'; wrapper.style.opacity = '1';
      card.style.borderRadius = '16px 16px 0 0'; chevron.style.transform = 'rotate(180deg)';
      setTimeout(() => wrapper.querySelector('select')?.focus(), 420);
    }
  }

  function filterLoans(q) {
    const rows  = document.querySelectorAll('#loans-table tbody tr');
    const term  = q.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const match = row.textContent.toLowerCase().includes(term);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const countEl = document.getElementById('loan-count');
    countEl.textContent = term ? `${visible} resultado(s)` : '';
  }
</script>

<%- include("../partials/footer") %>
