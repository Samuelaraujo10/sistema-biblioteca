<%- include("../partials/header") %>

<section class="page-heading">
  <h2>📖 Empréstimos</h2>
  <p>Controle retiradas, prazos e devoluções dos livros.</p>
</section>

<div class="loans-container">
  <!-- Alertas de vencimento -->
  <%
    const overdueLoans = loans.filter(l => l.dueDateStatus === 'overdue' && l.status === 'emprestado');
    const warningLoans = loans.filter(l => l.dueDateStatus === 'warning' && l.status === 'emprestado');
  %>

  <% if (overdueLoans.length > 0) { %>
    <div class="alert-overdue">
      <h3>⚠️ Empréstimos Vencidos</h3>
      <% overdueLoans.forEach((loan) => { %>
        <div class="alert-item">
          <strong><%= loan.book_title %></strong><br/>
          Locatário: <strong><%= loan.borrower_name %></strong> (<%= loan.borrower_type %>)
          <% if (loan.borrower_type === 'Aluno') { %>
            &nbsp;|&nbsp; Série: <%= loan.student_class || '-' %>
            &nbsp;|&nbsp; Turno: <%= loan.student_shift || '-' %>
          <% } %>
          <% if (loan.borrower_phone) { %>
            &nbsp;|&nbsp; 📞 <a href="https://wa.me/55<%= loan.borrower_phone.replace(/\D/g, '') %>" target="_blank" style="color:#155724;">(<%= loan.borrower_phone %>)</a>
          <% } %><br/>
          <span class="overdue-badge">Vencido há <%= Math.abs(loan.daysUntilDue) %> dia(s)</span>
        </div>
      <% }) %>
    </div>
  <% } %>

  <% if (warningLoans.length > 0) { %>
    <div class="alert-warning">
      <h3>⏰ Empréstimos Próximos ao Vencimento</h3>
      <% warningLoans.forEach((loan) => { %>
        <div class="alert-item">
          <strong><%= loan.book_title %></strong><br/>
          Locatário: <strong><%= loan.borrower_name %></strong> (<%= loan.borrower_type %>)
          <% if (loan.borrower_type === 'Aluno') { %>
            &nbsp;|&nbsp; Série: <%= loan.student_class || '-' %>
            &nbsp;|&nbsp; Turno: <%= loan.student_shift || '-' %>
          <% } %>
          <% if (loan.borrower_phone) { %>
            &nbsp;|&nbsp; 📞 <a href="https://wa.me/55<%= loan.borrower_phone.replace(/\D/g, '') %>" target="_blank" style="color:#856404;">(<%= loan.borrower_phone %>)</a>
          <% } %><br/>
          <span class="warning-badge">Vence em <%= loan.daysUntilDue %> dia(s)</span>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Barra de Ações -->
  <div style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
    <button id="btn-toggle-form" class="accent" style="display:flex; align-items:center; gap:8px;">
      <span style="font-size:1.1rem">➕</span> Registrar Novo Empréstimo
    </button>
    <div style="flex-grow: 1; position: relative; min-width: 250px;">
      <span style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; color: var(--muted);">🔍</span>
      <input id="loan-search" type="text" placeholder="Pesquisar por livro, aluno ou status..."
        oninput="filterLoans(this.value)" style="padding-left: 42px; width: 100%;" />
    </div>
  </div>

  <!-- Card de Cadastro Colapsável -->
  <div id="form-card" class="card" style="margin-bottom: 28px; border-top: 4px solid var(--primary); padding: 0; max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s var(--t), opacity 0.3s var(--t), padding 0.4s var(--t);">
    <form action="/loans" method="POST" style="margin: 0;">
      <h3 style="color: var(--text); font-size: 1.1rem; font-weight: 700; margin-bottom: 16px;">Novo Registro</h3>
      <div class="form-grid">
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Livro *</label>
          <select name="id_livro" required>
            <option value="">Selecione o livro</option>
            <% books.forEach((book) => { %>
              <% if (book.availableCopies > 0) { %>
                <option value="<%= book.id %>"><%= book.title %> (<%= book.availableCopies %> disponíveis)</option>
              <% } %>
            <% }) %>
          </select>
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Locatário *</label>
          <select name="borrower" required>
            <option value="">Selecione quem fará o empréstimo</option>
            <optgroup label="Alunos">
              <% students.forEach((student) => { %>
                <option value="student_<%= student.id %>"><%= student.name %></option>
              <% }) %>
            </optgroup>
            <optgroup label="Professores / Funcionários">
              <% staffList.forEach((staff) => { %>
                <option value="staff_<%= staff.id %>"><%= staff.name %> (<%= staff.type %>)</option>
              <% }) %>
            </optgroup>
          </select>
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Data Empréstimo *</label>
          <input type="date" name="loan_date" id="loan_date" required />
        </div>
        <div>
          <label style="display:block; margin-bottom:6px; font-size:0.88rem; color:var(--muted);">Devolução Prevista *</label>
          <input type="date" name="due_date" id="due_date" required />
        </div>
      </div>
      <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
        <button type="button" class="secondary" id="btn-cancel-form">Cancelar</button>
        <button type="submit">Salvar</button>
      </div>
    </form>
  </div>

  <div class="table-wrap">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding: 0 8px;">
      <h3 style="font-size: 1.1rem; font-weight: 700;">Histórico de Empréstimos</h3>
      <span style="font-size: 0.85rem; color: var(--muted);" id="loan-count">Total: <%= loans.length %></span>
    </div>
    <table id="loans-table">
      <thead>
        <tr>
          <th>Livro</th>
          <th>Locatário</th>
          <th>Data Empréstimo</th>
          <th>Data Devolução Prevista</th>
          <th>Status</th>
          <th>Ação</th>
        </tr>
      </thead>
      <tbody>
        <% loans.forEach((loan) => { %>
          <tr class="<%= loan.dueDateStatus === 'overdue' ? 'row-overdue' : loan.dueDateStatus === 'warning' ? 'row-warning' : '' %>">
            <td><%= loan.book_title %> (Cópia <%= loan.copy_id %>)</td>
            <td>
              <%= loan.borrower_name %><br/>
              <span style="font-size:0.78rem; color:var(--muted);"><%= loan.borrower_type %></span>
            </td>
            <td><%= loan.loan_date %></td>
            <td><%= loan.due_date %></td>
            <td>
              <span class="status-pill <%= loan.status === 'emprestado' ? 'is-active' : 'is-returned' %>">
                <%= loan.status %>
              </span>
              <% if (loan.dueDateStatus === 'overdue') { %>
                <span class="badge-overdue">Vencido</span>
              <% } else if (loan.dueDateStatus === 'warning') { %>
                <span class="badge-warning">Alerta</span>
              <% } %>
            </td>
            <td class="td-actions">
              <% if (loan.status === "emprestado") { %>
                <form action="/loans/<%= loan.id %>/return?_method=PATCH" method="POST" style="margin:0;">
                  <button type="submit" class="btn-action btn-return">✅ Devolver</button>
                </form>
                <% if (loan.dueDateStatus !== 'overdue') { %>
                  <form action="/loans/<%= loan.id %>/extend?_method=PATCH" method="POST" style="margin:0;">
                    <button type="submit" class="btn-action btn-renew">🔄 Renovar +7d</button>
                  </form>
                <% } %>
              <% } else { %>
                <span style="font-size:0.85rem;color:#6b7280;">✔ Devolvido em <%= loan.return_date %></span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const loanDateInput = document.getElementById('loan_date');
    const dueDateInput = document.getElementById('due_date');

    if (loanDateInput && dueDateInput) {
      const today = new Date();
      const todayStr = today.toISOString().split('T')[0];
      
      const defaultMaxDate = new Date(today);
      defaultMaxDate.setDate(defaultMaxDate.getDate() + 14);
      const defaultMaxDateStr = defaultMaxDate.toISOString().split('T')[0];

      loanDateInput.value = todayStr;
      dueDateInput.value = defaultMaxDateStr;
      
      loanDateInput.addEventListener('change', () => {
        const selectedLoan = new Date(loanDateInput.value);
        if(!isNaN(selectedLoan.getTime())) {
           const newMax = new Date(selectedLoan);
           newMax.setDate(newMax.getDate() + 14);
           dueDateInput.max = newMax.toISOString().split('T')[0];
           dueDateInput.min = loanDateInput.value;
        }
      });
      
      loanDateInput.dispatchEvent(new Event('change'));
    }
  });

    const btnToggle = document.getElementById('btn-toggle-form');
    const btnCancel = document.getElementById('btn-cancel-form');
    const formCard = document.getElementById('form-card');

    function openForm() {
      formCard.style.padding = '24px';
      formCard.style.maxHeight = '800px';
      formCard.style.opacity = '1';
      btnToggle.style.display = 'none';
      setTimeout(() => formCard.querySelector('select')?.focus(), 300);
    }

    function closeForm() {
      formCard.style.maxHeight = '0';
      formCard.style.opacity = '0';
      formCard.style.padding = '0';
      setTimeout(() => { btnToggle.style.display = 'flex'; }, 300);
    }

    btnToggle.addEventListener('click', openForm);
    btnCancel.addEventListener('click', closeForm);

  function filterLoans(q) {
    const rows  = document.querySelectorAll('#loans-table tbody tr');
    const term  = q.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const match = row.textContent.toLowerCase().includes(term);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const countEl = document.getElementById('loan-count');
    countEl.textContent = term ? `Filtrados: ${visible}` : `Total: ${rows.length}`;
  }
</script>

<%- include("../partials/footer") %>
