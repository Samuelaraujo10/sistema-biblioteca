<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistema Único de Biblioteca</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css" />
    <script>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-content">

        <!-- Brand -->
        <a href="/" class="topbar-brand" style="text-decoration:none;">
          <p class="eyebrow">Gestão Escolar</p>
          <h1>Sistema Único de Biblioteca</h1>
        </a>

        <div class="topbar-right">

          <!-- Grupo 1: navegação principal -->
          <nav class="nav-group" id="main-nav">
            <a href="/">🏠 Início</a>
            <a href="/books">📚 Livros</a>
            <a href="/students">👥 Alunos</a>
            <a href="/loans">📖 Empréstimos</a>
          </nav>

          <% if (user) { %>
            <!-- Separador visual -->
            <div class="nav-sep"></div>

            <!-- Grupo 2: utilitários -->
            <div class="nav-group">
              <span class="user-info">👤 <%= userName %></span>
              <a href="/backups" class="nav-icon-btn" title="Backups">
                💾
              </a>
            </div>

            <!-- Separador visual -->
            <div class="nav-sep"></div>

            <!-- Grupo 3: ações globais -->
            <div class="nav-group">
              <button id="theme-toggle" title="Alternar tema" aria-label="Alternar tema">🌙</button>
              <a href="/logout" class="logout-btn nav-icon-btn" title="Sair">⏏ Sair</a>
            </div>
          <% } else { %>
            <div class="nav-sep"></div>
            <div class="nav-group">
              <button id="theme-toggle" title="Alternar tema" aria-label="Alternar tema">🌙</button>
              <a href="/login" class="nav-icon-btn">Login</a>
            </div>
          <% } %>

          <!-- Hamburger (mobile) -->
          <button id="hamburger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </header>
    <main class="container">

    <script>
      // ── Dark Mode ─────────────────────────────────────────
      const toggleBtn = document.getElementById('theme-toggle');
      const root = document.documentElement;

      function applyTheme(theme) {
        root.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        if (toggleBtn) {
          toggleBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
          toggleBtn.title = theme === 'dark' ? 'Modo claro' : 'Modo escuro';
        }
      }
      applyTheme(root.getAttribute('data-theme') || 'light');
      if (toggleBtn) toggleBtn.addEventListener('click', () => {
        applyTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
      });

      // ── Hamburger ────────────────────────────────────────
      const hamburger = document.getElementById('hamburger');
      const mainNav   = document.getElementById('main-nav');
      const topbarRight = document.querySelector('.topbar-right');

      if (hamburger) {
        hamburger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = topbarRight.classList.toggle('open');
          hamburger.classList.toggle('open', isOpen);
          hamburger.setAttribute('aria-expanded', isOpen);
        });

        document.addEventListener('click', (e) => {
          if (!topbarRight.contains(e.target)) {
            topbarRight.classList.remove('open');
            hamburger.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
          }
        });
      }
    </script>
